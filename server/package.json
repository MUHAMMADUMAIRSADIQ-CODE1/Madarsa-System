{
  "name": "jamia-tul-uloom-muhammadiya-api",
  "version": "1.0.0",
  "description": "Backend API for Jamia Tul Uloom Muhammadiya - Online Islamic Academy Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --setupFiles dotenv/config --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --setupFiles dotenv/config --watchAll",
    "test:coverage": "cross-env NODE_ENV=test jest --setupFiles dotenv/config --coverage",
    "lint": "eslint src/"
  },
  "keywords": [
    "islamic-academy",
    "lms",
    "madarsa",
    "education",
    "jamia",
    "express",
    "mongodb"
